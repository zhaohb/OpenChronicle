# Copy to .env and edit as needed.
# Both example apps target a local Ollama OpenVINO server by default.

# --- OpenChronicle MCP endpoint ---
OC_MCP_URL=http://127.0.0.1:8742/mcp

# --- Local LLM (Ollama / Ollama OpenVINO via litellm, same as OpenChronicle daemon) ---
# Default values shown below; uncomment to override.

# Origin only, or legacy .../v1 — trailing /v1 is stripped for litellm api_base.
OC_LLM_BASE_URL=http://127.0.0.1:11434
# Bare Ollama name or full litellm id ollama/<name>
OC_LLM_MODEL=qwen3_8b_ov:v1
# OC_LLM_API_KEY=ollama

# Notes:
# 1. Example apps use litellm.completion(ollama/..., api_base=...). For localhost,
#    NO_PROXY is patched like openchronicle.writer.llm (corporate proxy loopback fix).
# 2. httpx health_check still uses trust_env=False for GET /api/version.
# 3. Pick any model you have pulled into Ollama OpenVINO. Tool/JSON-mode-capable models
#    are required (e.g. qwen2.5:7b, qwen2.5:14b, llama3.1:8b).
# 3. To probe the server quickly:
#       curl http://127.0.0.1:11434/api/version
#       curl http://127.0.0.1:11434/api/show -d '{"model":"qwen2.5:7b"}'
